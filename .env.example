# Database credentials (used by docker-compose to create the database)
DB_USER=
DB_PASSWORD=
DB_NAME=

# Full database URL
# Local:     postgresql://user:password@localhost:5433/db_name
# Docker:    postgresql://user:password@db:5432/db_name
# Hosted:    postgresql://user:password@your_host:5432/db_name
DATABASE_URL=

# Ollama base URL
# Local:     http://localhost:11434
# Docker:    http://host.docker.internal:11434
# Hosted:    https://your-ollama-host:11434
OLLAMA_BASE_URL=

# Backend URL (used by frontend)
# Local:     http://localhost:8000
# Docker:    http://backend:8000
# Hosted:    https://your-backend-url
BACKEND_URL=

# Frontend URL (used by backend for CORS)
# Local:     http://localhost:8501
# Docker:    http://localhost:8501
# Hosted:    https://your-frontend-url
FRONTEND_URL=
